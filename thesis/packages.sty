% Chapter and part title styles
\usepackage{titlesec}

\titleformat{\chapter}[display]
  {\normalfont\bfseries\raggedright}
  {\Large\chaptertitlename\ \thechapter}
  {0.5em}
  {\huge}
  [\vspace{0.5em}\titlerule]

\titlespacing*{\chapter}
  {0pt}
  {0pt}
  {2.5em}

\titleformat{\part}[display]
  {\normalfont\centering\bfseries}
  {\Large\partname\ \thepart}
  {1em}
  {\Huge}
  [\vspace{1em}\titlerule]

\titlespacing*{\part}
  {0pt}
  {5em}
  {5em}

% Float placement settings — avoids float-only pages and large blank gaps
\renewcommand{\topfraction}{0.85}
\renewcommand{\bottomfraction}{0.70}
\renewcommand{\textfraction}{0.10}
\renewcommand{\floatpagefraction}{0.75}
\setcounter{topnumber}{3}
\setcounter{bottomnumber}{2}
\setcounter{totalnumber}{5}

% Simple page style
\pagestyle{plain}

% TOC entry spacing — neutralises \parskip leaking into TOC entries and tightens sections
\usepackage[titles]{tocloft}
\setlength{\cftbeforepartskip}{1.5em}
\setlength{\cftbeforechapskip}{1.2em}
\setlength{\cftbeforesecskip}{0.5em}
